{
  "name": "mhglauncher-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": { "node": ">=24.17.0 <25" },
  "scripts": {
    "dev": "tsx server.ts",
    "build": "next build && tsup server.ts --format esm --out-dir build --external next --external better-sqlite3",
    "start": "NODE_ENV=production node build/server.js",
    "typecheck": "next typegen && tsc --noEmit",
    "lint": "eslint . && knip",
    "test": "vitest run"
  },
  "dependencies": {
    "better-sqlite3": "12.11.1",
    "next": "16.2.11",
    "protobufjs": "8.7.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "xxhash-wasm": "1.1.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "24.10.13",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.2",
    "knip": "6.17.1",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vitest": "4.1.9"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "postcss": "8.5.22",
    "sharp": "0.35.3"
  }
}
